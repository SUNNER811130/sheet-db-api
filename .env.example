SPREADSHEET_ID=
SHEETS_MEMBERS_TAB=members

# Protect /members endpoints (keep /health public)
API_KEY=

# Local only:
# - On your machine, point this to a Service Account JSON key
# - On Cloud Run (Scheme A), you do NOT set this. Cloud Run uses the attached
#   runtime Service Account via ADC.
GOOGLE_APPLICATION_CREDENTIALS=

# LINE webhook reply behavior: "off" (default) or "on"
LINE_REPLY_MODE=off
